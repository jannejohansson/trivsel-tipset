{
    "routes": [
        {
            "route": "/api/*",
            "allowedRoles": ["anonymous"]
        }
    ],
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": ["/api/*", "*.html", "*.ico", "*.png", "*.jpg", "*.jpeg", "*.js", "*.css", "*.json"]
    },
    "globalHeaders": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY"
    }
}
